@model FlightSearchEngine.Models.SearchViewModel

@{
    ViewData["Title"] = "Flight Search";
}

<style>
    body {
        background-color: #f4f7fa;
    }

    .search-container {
        margin-top: 80px;
    }

    .search-card {
        border-radius: 15px;
        border: none;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        padding: 35px;
        background-color: #ffffff;
    }

    .form-control, .form-select {
        border-radius: 8px;
    }

    .btn-primary-custom {
        background-color: #2c7be5;
        border: none;
        border-radius: 25px;
        padding: 10px 25px;
    }

        .btn-primary-custom:hover {
            background-color: #1a5ec8;
        }

    .btn-secondary-custom {
        background-color: #6c757d;
        border: none;
        border-radius: 25px;
        padding: 10px 25px;
    }

        .btn-secondary-custom:hover {
            background-color: #5a6268;
        }
</style>

<div class="container search-container">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="search-card">

                <h4 class="text-center mb-4 text-dark">
                    Flight Search
                </h4>

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Source</label>
                        <select asp-for="Source" asp-items="Model.SourceList" class="form-select">
                            <option value="">Select Source</option>
                        </select>
                        <span asp-validation-for="Source" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Destination</label>
                        <select asp-for="Destination" asp-items="Model.DestinationList" class="form-select">
                            <option value="">Select Destination</option>
                        </select>
                        <span asp-validation-for="Destination" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Number of Persons</label>
                        <input asp-for="NumberOfPersons" type="number" min="1" max="10"
                               class="form-control"
                               placeholder="Enter number of persons" />
                        <span asp-validation-for="NumberOfPersons" class="text-danger"></span>
                    </div>

                    <div class="text-center">
                        <button type="submit"
                                formaction="@Url.Action("SearchFlights")"
                                class="btn btn-primary-custom me-2"
                                onclick="showSpinner()">
                            Flights Only
                        </button>

                        <button type="submit"
                                formaction="@Url.Action("SearchFlightsWithHotels")"
                                class="btn btn-secondary-custom"
                                onclick="showSpinner()">
                            Flight + Hotel
                        </button>
                    </div>

                    <!-- Spinner -->
                    <div class="text-center mt-3" id="loadingSpinner" style="display:none;">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2">Searching...</p>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.querySelector("form").addEventListener("submit", function (e) {
            var source = document.getElementById("Source").value;
            var destination = document.getElementById("Destination").value;

            if (source && destination && source === destination) {
                alert("Source and Destination cannot be the same.");
                e.preventDefault();
                return false;
            }
        });

        function showSpinner() {
            document.getElementById("loadingSpinner").style.display = "block";
        }
    </script>
}