@model LibraryApp.Models.Book

<h2>Add New Book</h2>

<form method="post" asp-action="Create">

    <div>
        <label>Title</label>
        <input asp-for="Title" />
    </div>

    <div>
        <label>Author</label>
        <input asp-for="Author" />
    </div>

    <div>
        <label>Price</label>
        <input asp-for="Price" />
    </div>

    <br>

    <button type="submit">Save</button>

</form>

<a href="/Book/List">Back to List</a>